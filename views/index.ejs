<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title></title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900">
        <div class="form">
            <form class="form p-10 text-white" action="/create" method="POST">
                <input class="block w-full bg-zinc-800 outline-none rounded-md px-5 py-2 " placeholder="Title" type="text" name="title" id="task-title">
                <textarea class="block w-full bg-zinc-800 outline-none resize-none rounded-md px-5 py-2 mt-2 " placeholder="Description" name="desc" id="task-desc"></textarea>
                <input  class="mt-2 bg-blue-800 px-5 py-2 rounded-md" type="submit" value="submit">
            </form>
        </div>
        <div class="tasks p-10 flex gap-3 flex-wrap">
            <% if (files.length > 0) { %>
                <% files.forEach((file) => { %>
                    <div class="task min-w-72 px-3 py-4 rounded-md bg-zinc-800">
                        <h1 class="text-white text-3xl tracking-tighter"><%= file %></h1>
                        <a class="text-sky-800 inline-block mt-2" href="/file/<%= file %>">View</a>
                    </div>
                <% }) %>
            <% } else { %>
                <h3 class="text-zinc-600">No task yet.</h3>
            <% } %>
        </div>
    </div>
</body>
</html>